---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { excerpt, formatDate, inferTags, postUrl } from '../lib/blog';

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const tags = post.data.tags?.length ? post.data.tags : inferTags(post);
---

<article class="post-card">
	{
		post.data.heroImage && (
			<a class="post-media" href={postUrl(post)} aria-label={post.data.title}>
				<Image width={900} height={430} src={post.data.heroImage} alt={post.data.title} />
			</a>
		)
	}
	<div class="post-body">
		<h2>
			<a href={postUrl(post)}>{post.data.title}</a>
		</h2>
		<p class="excerpt">{excerpt(post, 170)}</p>
		<div class="post-meta">
			<time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
			<span>·</span>
			<a href={`/categories/${encodeURIComponent(post.data.category)}/`}>{post.data.category}</a>
			<span>·</span>
			<span>{tags.slice(0, 2).join(' / ')}</span>
			<a class="read-more" href={postUrl(post)}>继续阅读</a>
		</div>
	</div>
</article>

<style>
	.post-media {
		display: block;
		background: var(--surface-muted);
	}

	.post-media img {
		display: block;
		width: 100%;
		aspect-ratio: 2.8 / 1;
		object-fit: cover;
		border-radius: 0;
	}

	.post-body {
		padding: 22.5px;
	}

	h2 {
		margin: 0 0 15px;
		color: var(--text-strong);
		font-size: 22.5px;
		font-weight: 400;
		line-height: 25.3125px;
	}

	h2 a {
		color: var(--text-strong);
	}

	h2 a:hover {
		color: var(--accent);
	}

	.excerpt {
		margin: 0 0 15px;
		color: var(--text);
		font-size: 15px;
		line-height: 22.5px;
	}

	.post-meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 4px;
		color: var(--text-muted);
		font-size: 15px;
		line-height: 22.5px;
	}

	.read-more {
		margin-left: auto;
	}

	@media (max-width: 760px) {
		.post-body {
			padding: 20px 22px;
		}

		.post-meta {
			gap: 6px;
		}

		.read-more {
			margin-left: 0;
			width: 100%;
			text-align: right;
		}
	}
</style>

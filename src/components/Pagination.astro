---
import { pageUrl } from '../lib/blog';

interface Props {
	currentPage: number;
	totalPages: number;
}

const { currentPage, totalPages } = Astro.props;

function paginationItems(current: number, total: number) {
	if (total <= 5) return Array.from({ length: total }, (_, index) => index + 1);
	if (current <= 2) return [1, 2, 'ellipsis', total] as const;
	if (current >= total - 1) return [1, 'ellipsis', total - 1, total] as const;
	return [1, 'ellipsis', current, 'ellipsis', total] as const;
}

const items = paginationItems(currentPage, totalPages);
const hasPrevious = currentPage > 1;
const hasNext = currentPage < totalPages;
---

{
	totalPages > 1 && (
		<nav class="pagination" aria-label="分页">
			{
				hasPrevious ? (
					<a class="page-side" href={pageUrl(currentPage - 1)}>上一页</a>
				) : (
					<span class="page-side page-side--ghost" aria-hidden="true" />
				)
			}
			<div class="page-counter">{currentPage}/{totalPages}</div>
			<ul class="page-list">
				{items.map((item) => (
					<li>
						{
							item === 'ellipsis' ? (
								<span class="page-ellipsis">…</span>
							) : (
								<a class:list={['page-number', { 'is-current': item === currentPage }]} href={pageUrl(item)}>
									{item}
								</a>
							)
						}
					</li>
				))}
			</ul>
			{
				hasNext ? (
					<a class="page-side" href={pageUrl(currentPage + 1)}>下一页</a>
				) : (
					<span class="page-side page-side--ghost" aria-hidden="true" />
				)
			}
		</nav>
	)
}

<style>
	.pagination {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin: 22.5px -3.75px 0;
		color: var(--text);
		font-size: 15px;
	}

	.page-list {
		display: flex;
		align-items: center;
		justify-content: center;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.page-list li {
		margin: 0 3.75px;
	}

	.page-number,
	.page-side {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 34px;
		min-height: 34px;
		padding: 7.5px 11.25px;
		border-radius: 8px;
		background: var(--surface);
		color: var(--text);
		line-height: 1;
	}

	.page-side {
		min-width: 68px;
		margin: 0 3.75px;
	}

	.page-number:hover,
	.page-side:hover {
		background: var(--surface-strong);
		color: var(--text-strong);
	}

	.page-number.is-current {
		background: #c3c7cb;
		color: #2f3947;
	}

	.page-ellipsis {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 30px;
		height: 34px;
		color: var(--text);
		line-height: 1;
	}

	.page-side--ghost {
		background: transparent;
		pointer-events: none;
	}

	.page-counter {
		display: none;
	}

	@media (max-width: 760px) {
		.pagination {
			margin-top: 22px;
		}

		.page-list {
			display: none;
		}

		.page-counter {
			display: block;
			color: var(--muted);
		}
	}
</style>

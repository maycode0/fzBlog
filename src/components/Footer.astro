---
import { siteConfig } from '../config';

const today = new Date();
const { title } = siteConfig;
---

<footer class="site-footer">
	<p>
		Copyright &copy; 2025 - {today.getFullYear()}
		<a href="/">{title}</a>
	</p>
	<p>
		Powered by <a href="https://astro.build/">Astro</a> 
		& Design inspired by <a href="https://blog.skk.moe/">Sukka</a> .
	</p>
</footer>

<style>
	.site-footer {
		padding: 45px 22.5px 90px;
		background: var(--surface);
		color: var(--text-muted);
		font-size: 15px;
		line-height: 22.5px;
		text-align: center;
	}

	.site-footer p {
		display: inline;
		margin: 0;
	}

	.site-footer p + p::before {
		content: " ";
	}
</style>

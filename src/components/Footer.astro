---
import { SITE_TITLE } from '../consts';

const today = new Date();
---

<footer class="site-footer">
	<p>
		Copyright &copy; 2018 - {today.getFullYear()}
		<a href="/">{SITE_TITLE}</a>
	</p>
	<p>
		Powered by <a href="https://astro.build/">Astro</a> &amp; designed for a quiet reading experience.
	</p>
</footer>

<style>
	.site-footer {
		padding: 45px 22.5px 90px;
		background: var(--surface);
		color: var(--text-muted);
		font-size: 15px;
		line-height: 22.5px;
		text-align: center;
	}

	.site-footer p {
		display: inline;
		margin: 0;
	}

	.site-footer p + p::before {
		content: " ";
	}
</style>

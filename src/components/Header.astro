---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<nav class="site-nav" aria-label="主导航">
		<a class="brand" href="/" aria-label={`${SITE_TITLE} 首页`}>
			<span class="brand-mark">FZ</span>
			<span>{SITE_TITLE}</span>
		</a>

		<div class="nav-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/archives/">归档</HeaderLink>
			<HeaderLink href="/tags/">标签</HeaderLink>
			<HeaderLink href="/links/">友链</HeaderLink>
			<HeaderLink href="/about/">About Me</HeaderLink>
		</div>

		<div class="nav-tools">
			<a class="icon-button" href="/rss.xml" aria-label="订阅 Atom RSS" title="RSS">
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path d="M5 5.7a13.3 13.3 0 0 1 13.3 13.3" />
					<path d="M5 11a8 8 0 0 1 8 8" />
					<circle class="icon-fill" cx="6.2" cy="18.8" r="1.35" />
				</svg>
			</a>
			<a class="icon-button" href="/search/" aria-label="搜索" title="搜索">
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<circle cx="11" cy="11" r="7" />
					<path d="m20 20-4.3-4.3" />
				</svg>
			</a>
			<a class="icon-button" href="https://github.com/maycode0" aria-label="GitHub" title="GitHub" target="_blank" rel="noopener noreferrer">
				<svg viewBox="0 0 24 24" aria-hidden="true">
					<path
						class="icon-fill"
						d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.7-3.88-1.54-3.88-1.54-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.55-.29-5.23-1.28-5.23-5.68 0-1.25.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.16 1.18A10.96 10.96 0 0 1 12 5.52c.98 0 1.96.13 2.88.4 2.19-1.49 3.15-1.18 3.15-1.18.63 1.58.24 2.75.12 3.04.74.8 1.18 1.83 1.18 3.08 0 4.42-2.69 5.38-5.25 5.67.42.36.78 1.06.78 2.14 0 1.54-.01 2.78-.01 3.16 0 .31.21.68.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"
					/>
				</svg>
			</a>
			<button class="icon-button theme-toggle" type="button" aria-label="切换到浅色模式" title="切换到浅色模式">
				<svg class="theme-icon theme-icon--sun" viewBox="0 0 24 24" aria-hidden="true">
					<circle cx="12" cy="12" r="4" />
					<path d="M12 2v2" />
					<path d="M12 20v2" />
					<path d="m4.93 4.93 1.41 1.41" />
					<path d="m17.66 17.66 1.41 1.41" />
					<path d="M2 12h2" />
					<path d="M20 12h2" />
					<path d="m6.34 17.66-1.41 1.41" />
					<path d="m19.07 4.93-1.41 1.41" />
				</svg>
				<svg class="theme-icon theme-icon--moon" viewBox="0 0 24 24" aria-hidden="true">
					<path d="M20.7 14.2A8.2 8.2 0 0 1 9.8 3.3a8.8 8.8 0 1 0 10.9 10.9Z" />
				</svg>
			</button>
		</div>
	</nav>
</header>

<script>
	function getHeaderTheme(): 'light' | 'dark' {
		return document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
	}

	function syncHeaderThemeButton(button: HTMLButtonElement, theme: 'light' | 'dark') {
		const nextLabel = theme === 'dark' ? '切换到浅色模式' : '切换到深色模式';
		button.dataset.theme = theme;
		button.setAttribute('aria-label', nextLabel);
		button.title = nextLabel;
	}

	function initHeaderThemeToggle() {
		const buttons = [...document.querySelectorAll<HTMLButtonElement>('.theme-toggle')];
		for (const button of buttons) {
			syncHeaderThemeButton(button, getHeaderTheme());
			if (button.dataset.themeToggleBound === 'true') continue;
			button.dataset.themeToggleBound = 'true';
			button.addEventListener('click', () => {
				const next = getHeaderTheme() === 'dark' ? 'light' : 'dark';
				document.documentElement.dataset.theme = next;
				document.documentElement.style.colorScheme = next;
				try {
					localStorage.setItem('theme', next);
				} catch {
					// Ignore storage failures; the visual theme still changes for this page.
				}
				for (const item of document.querySelectorAll<HTMLButtonElement>('.theme-toggle')) {
					syncHeaderThemeButton(item, next);
				}
			});
		}
	}

	const headerWindow = window as typeof window & {
		__fzInitHeaderThemeToggle?: () => void;
		__fzHeaderThemeLifecycleBound?: boolean;
		__fzApplyTheme?: () => void;
	};

	headerWindow.__fzInitHeaderThemeToggle = initHeaderThemeToggle;
	if (!headerWindow.__fzHeaderThemeLifecycleBound) {
		document.addEventListener('astro:after-swap', () => headerWindow.__fzApplyTheme?.());
		document.addEventListener('astro:page-load', () => headerWindow.__fzInitHeaderThemeToggle?.());
		headerWindow.__fzHeaderThemeLifecycleBound = true;
	}
	initHeaderThemeToggle();
</script>

<style>
	.site-header {
		position: relative;
		z-index: 30;
		background: var(--surface);
	}

	.site-nav {
		display: flex;
		align-items: center;
		width: min(calc(var(--container) - 45px), calc(100% - 69px));
		height: 57px;
		margin: 0 auto;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		flex: 0 0 175.86px;
		gap: 12px;
		min-width: 0;
		margin-left: -11.25px;
		margin-right: 11.25px;
		padding: 15px 12px;
		color: var(--text);
		font-size: 18px;
		font-weight: 700;
		line-height: 27px;
		white-space: nowrap;
	}

	.brand:hover {
		color: var(--text-strong);
	}

	.brand-mark {
		display: grid;
		width: 27px;
		height: 27px;
		place-items: center;
		border-radius: 50%;
		background:
			radial-gradient(circle at 32% 30%, #f6d88c 0 16%, transparent 17%),
			linear-gradient(135deg, #13a8d8, #465a76);
		color: #0f1722;
		font-size: 11px;
		font-weight: 700;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 0;
		justify-content: flex-start;
		margin-right: auto;
	}

	.nav-tools {
		display: flex;
		align-items: center;
		gap: 0;
		margin-right: -11.25px;
	}

	.icon-button svg {
		display: block;
		width: 15px;
		height: 15px;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 2;
	}

	.icon-button .icon-fill {
		fill: currentColor;
		stroke: none;
	}

	.icon-button .theme-icon--moon {
		display: none;
	}

	:global(:root[data-theme='light']) .theme-icon--sun {
		display: none;
	}

	:global(:root[data-theme='light']) .theme-icon--moon {
		display: block;
	}

	@media (max-width: 760px) {
		.site-nav {
			display: grid;
			grid-template-columns: 1fr auto;
			grid-template-rows: auto auto;
			gap: 4px 12px;
			width: calc(100% - 24px);
			height: auto;
			padding: 10px 0 8px;
		}

		.brand {
			font-size: 1rem;
		}

		.nav-links {
			grid-column: 1 / -1;
			overflow-x: auto;
			padding: 0 0 2px;
		}

		.nav-links::-webkit-scrollbar {
			display: none;
		}

		.nav-tools {
			justify-content: flex-end;
		}
	}
</style>

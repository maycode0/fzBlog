---
import { getCollection } from 'astro:content';
import BackToTop from '../../components/BackToTop.astro';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import Sidebar from '../../components/Sidebar.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { sortPosts } from '../../lib/blog';

const posts = sortPosts(await getCollection('blog'));
---

<!doctype html>
<html lang="zh-CN" id="top">
	<head>
		<BaseHead title={`文章 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="page-shell">
			<Sidebar posts={posts} side="left" />
			<section class="content-stack" aria-label="文章列表">
				{posts.map((post) => <PostCard post={post} />)}
			</section>
			<Sidebar posts={posts} side="right" />
		</main>
		<BackToTop />
		<Footer />
	</body>
</html>

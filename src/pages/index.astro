---
import { getCollection } from 'astro:content';
import BackToTop from '../components/BackToTop.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Pagination from '../components/Pagination.astro';
import PostCard from '../components/PostCard.astro';
import Sidebar from '../components/Sidebar.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { pagePosts, sortPosts, totalPages } from '../lib/blog';

const posts = sortPosts(await getCollection('blog'));
const currentPage = 1;
const pages = totalPages(posts);
const visiblePosts = pagePosts(posts, currentPage);
---

<!doctype html>
<html lang="zh-CN" id="top">
	<head>
		<BaseHead title={`首页 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="page-shell">
			<Sidebar posts={posts} side="left" />
			<section class="content-stack" aria-label="文章列表">
				{visiblePosts.map((post) => <PostCard post={post} />)}
				<Pagination currentPage={currentPage} totalPages={pages} />
			</section>
			<Sidebar posts={posts} side="right" />
		</main>
		<BackToTop />
		<Footer />
	</body>
</html>

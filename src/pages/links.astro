---
import { getCollection } from 'astro:content';
import BackToTop from '../components/BackToTop.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { sortPosts } from '../lib/blog';

const posts = sortPosts(await getCollection('blog'));
const links = [
	{
		name: 'Linux.do',
		url: 'https://linux.do/',
		description: '新的理想型社区',
		icon: 'https://www.google.com/s2/favicons?domain=linux.do&sz=256',
		initials: 'LD',
	},
	{
		name: 'IDC Flare',
		url: 'https://idcflare.com/',
		description: 'idcflare.com',
		icon: 'https://idcflare.com/uploads/default/original/1X/27321bd8c4301b325bf5e4524772bb39ece5424e.png',
		initials: 'IF',
	},
	{
		name: 'Astro',
		url: 'https://astro.build/',
		description: 'The web framework for content-driven websites',
		icon: 'https://astro.build/assets/press/astro-icon-light-gradient.png',
	},
];
---

<!doctype html>
<html lang="zh-CN" id="top">
	<head>
		<BaseHead title={`友链 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="page-shell">
			<Sidebar posts={posts} side="left" />
			<section class="content-stack" aria-label="友链">
				<ul class="friend-links">
					{
						links.map((link) => (
							<li>
								<a class="friend-card" href={link.url} target="_blank" rel="noopener noreferrer">
									<span class="friend-icon" aria-hidden="true">
										<span>{link.initials}</span>
										{link.icon && <img src={link.icon} alt="" loading="lazy" decoding="async" onerror="this.hidden = true" />}
									</span>
									<span class="friend-copy">
										<strong>{link.name}</strong>
										<small>{link.description}</small>
									</span>
								</a>
							</li>
						))
					}
				</ul>
			</section>
			<Sidebar posts={posts} side="right" />
		</main>
		<BackToTop />
		<Footer />
	</body>
</html>

<style>
	.friend-links {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 22.5px;
		margin: 22.5px 0 0;
		padding: 0;
		list-style: none;
	}

	.friend-card {
		display: flex;
		align-items: center;
		min-height: 76px;
		overflow: hidden;
		border: 1px solid var(--border);
		border-radius: 6px;
		background: var(--surface);
		color: var(--text);
		box-shadow: var(--shadow);
		transition:
			border-color 160ms ease,
			transform 160ms ease,
			background-color 160ms ease;
	}

	.friend-card:hover {
		border-color: color-mix(in srgb, var(--accent) 52%, var(--border));
		background: var(--surface-muted);
		color: var(--text);
		transform: translateY(-1px);
	}

	.friend-icon {
		position: relative;
		display: grid;
		flex: 0 0 74px;
		width: 74px;
		align-self: stretch;
		min-height: 74px;
		place-items: center;
		overflow: hidden;
		background: black;
		color: #fff;
		font-size: 22px;
		font-weight: 700;
		line-height: 1;
	}

	.friend-icon img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.friend-copy {
		display: flex;
		min-width: 0;
		flex-direction: column;
		gap: 4px;
		padding: 0 14px;
	}

	.friend-copy strong {
		overflow: hidden;
		color: var(--text-strong);
		font-size: 18px;
		font-weight: 700;
		line-height: 22px;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.friend-copy small {
		overflow: hidden;
		color: var(--muted);
		font-size: 14px;
		line-height: 20px;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	@media (max-width: 760px) {
		.friend-links {
			grid-template-columns: 1fr;
			gap: 16px;
		}
	}

	@media (max-width: 420px) {
		.friend-card {
			min-height: 74px;
		}

		.friend-icon {
			flex-basis: 72px;
			width: 72px;
			min-height: 72px;
		}

		.friend-copy {
			padding: 0 14px;
		}

		.friend-copy strong {
			font-size: 18px;
			line-height: 23px;
		}

		.friend-copy small {
			font-size: 14px;
			line-height: 20px;
		}
	}
</style>
